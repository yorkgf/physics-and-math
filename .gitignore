# Obsidian configuration (device-specific, don't sync)
.obsidian/
# Keep shared plugins/themes if you want to sync them
# !/.obsidian/plugins/
# !/.obsidian/themes/

# Agent client sessions (device-specific)
.obsidian/plugins/agent-client/sessions/
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Claude Code configuration (device-specific, don't sync)
.claude/

# Operating system files
.DS_Store
Thumbs.db

# Vault hidden files
.trash/

# Temporary files
*.tmp
*.temp
